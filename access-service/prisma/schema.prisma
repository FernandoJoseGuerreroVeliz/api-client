generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["access"]
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model countries {
  code         String  @id @db.Char(2)
  name         String  @db.VarChar(100)
  phone_prefix String  @db.VarChar(10)
  users        users[]
  @@schema("access")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model roles {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String    @unique @db.VarChar(50)
  description String?
  status      Boolean   @default(true)
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  users       users[]
  @@schema("access")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model user_sessions {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String    @db.Uuid
  refresh_token String
  device_type   String?   @db.VarChar(20)
  device_name   String?   @db.VarChar(100)
  device_id     String?   @db.VarChar(255)
  ip_address    String?   @db.VarChar(50)
  user_agent    String?
  created_at    DateTime? @default(now()) @db.Timestamptz(6)
  last_used_at  DateTime? @db.Timestamptz(6)
  expires_at    DateTime  @db.Timestamptz(6)
  revoked       Boolean?  @default(false)
  users         users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_session_user")

  @@index([expires_at], map: "idx_sessions_expires_at")
  @@index([refresh_token], map: "idx_sessions_refresh_token")
  @@index([user_id], map: "idx_sessions_user_id")

  @@schema("access")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model user_status {
  name        String    @id @db.VarChar(50)
  description String?
  status      Boolean   @default(true)
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  users       users[]

  @@schema("access")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model users {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String          @db.VarChar(120)
  email         String          @unique @db.VarChar(120)
  photo_url     String?
  country_code  String?         @db.Char(2)
  phone         String?         @db.VarChar(20)
  password_hash String
  role_name     String          @db.VarChar(50)
  status_name   String          @default("PENDING") @db.VarChar(50)
  created_at    DateTime?       @default(now()) @db.Timestamptz(6)
  user_sessions user_sessions[]
  countries     countries?      @relation(fields: [country_code], references: [code], onDelete: NoAction, onUpdate: NoAction, map: "fk_user_country")
  roles         roles           @relation(fields: [role_name], references: [name], onDelete: NoAction, onUpdate: NoAction, map: "fk_user_role")
  user_status   user_status     @relation(fields: [status_name], references: [name], onDelete: NoAction, onUpdate: NoAction, map: "fk_user_status")
  @@schema("access")
}

